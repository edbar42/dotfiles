font-family = CaskaydiaCove NF

{{- if eq .chezmoi.hostname "thinkpad" }}
font-size = 18
{{- else }}
font-size = 14
{{- end }}
font-feature = calt
font-frature = liga
font-feature = clig

# --- Colors ---
theme = One Double Dark

# --- Background ---
background-opacity = 0.75

# --- Inactive pane dimming ---
# wezterm used saturation=0.7, brightness=0.4 — Ghostty only has opacity control.
unfocused-split-opacity = 0.4

# --- Window padding ---
window-padding-x = 8
window-padding-y = 4

# --- Tab bar ---
gtk-custom-css = ~/.config/ghostty/custom.css
window-new-tab-position = current
window-show-tab-bar = auto
gtk-tabs-location = bottom

# -- Misc --
copy-on-select = true

# --- Keybindings ---
# Tabs
keybind = alt+t=new_tab
keybind = alt+n=next_tab
keybind = alt+p=previous_tab
keybind = alt+r=prompt_tab_title

# Splits
keybind = alt+enter=new_split:right
keybind = alt+shift+enter=new_split:down
keybind = alt+m=toggle_split_zoom
keybind = alt+q=close_surface

# Navigate panes
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right

# Resize panes
keybind = alt+shift+h=resize_split:left,50
keybind = alt+shift+j=resize_split:down,50
keybind = alt+shift+k=resize_split:up,50
keybind = alt+shift+l=resize_split:right,50

# Unbind default CTRL +/-/= font size bindings
keybind = ctrl+minus=unbind
keybind = ctrl+equal=unbind
keybind = ctrl+shift+equal=unbind

# NOTE: the following have no Ghostty equivalent and were not migrated:
#   ALT+SHIFT+t  — new tab with prompted name
#   ALT+v        — copy mode
#   ALT+g        — spawn yazi in new tab
#   ALT+f        — fuzzy tab switcher
