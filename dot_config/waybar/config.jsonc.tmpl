{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 0,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/waycal", "clock"],
  "modules-right": [
    "memory",
    "custom/cputemp",
    "custom/gputemp",
    "network",
    "battery",
    "pulseaudio",
    "group/quick-settings"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },

  "clock": {
    "format": "{:L%H:%M}",
    "locale": "pt_BR.UTF-8",
    "calendar": {}
  },

  "memory": {
    "format": "๎ฟ  {}%",
    "interval": 2,
    "on-click": "~/.bin/tui-float btop"
  },

  "custom/cputemp": {
    "exec": "~/.bin/temperature",
    "interval": 2,
    "on-click": "~/.bin/tui-float btop",
    "format": "๓ฐป  {text}",
    "format-warn": "๓ฐป  {%text}",
    "format-critical": "๓ฐป  {%text}",
    "return-type": "json"
  },

  {{- if eq .chezmoi.hostname "desktop" }}
  "custom/gputemp": {
    "exec": "~/.bin/temperature --chip nvidia",
    "interval": 2,
    "on-click": "~/.bin/tui-float btop",
    "format": "๓ฐขฎ {text}",
    "format-warn": "๓ฐขฎ {%text}",
    "format-critical": "๓ฐขฎ {%text}",
    "return-type": "json"
  },
  {{- end }}

  {{- if eq .chezmoi.hostname "thinkpad" }}
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{icon}",
    "format-charging": "{icon}",
    "format-plugged": "",
    "format-icons": {
      "charging": ["๓ฐข", "๓ฐ", "๓ฐ", "๓ฐ", "๓ฐข", "๓ฐ", "๓ฐข", "๓ฐ", "๓ฐ", "๓ฐ"],
      "default": ["๓ฐบ", "๓ฐป", "๓ฐผ", "๓ฐฝ", "๓ฐพ", "๓ฐฟ", "๓ฐ", "๓ฐ", "๓ฐ", "๓ฐน"]
    },
    "format-full": "๓ฐ",
    "tooltip-format-discharging": "{power:>1.0f}Wโ {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}Wโ {capacity}%",
    "interval": 5,
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  {{- end }}

  "network": {
    "format-icons": ["๓ฐคฏ", "๓ฐค", "๓ฐคข", "๓ฐคฅ", "๓ฐคจ"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)",
    "tooltip-format-ethernet": "Connected",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "format-ethernet": "๓ฐ {ifname}",
    "format-linked": "{ifname} (No IP)",
    "format-disconnected": "๓ฐคฎ ",
    "on-click": "~/.bin/tui-float impala"
  },

  "group/quick-settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "quick-settings-item",
      "transition-left-to-right": false
    },
    "modules": ["custom/expand-icon", "hyprland/language", "tray"]
  },

  "custom/expand-icon": {
    "format": "๏",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "๓ฐ",
    "on-click": "~/.bin/tui-float wiremix",
    "scroll-step": 5,
    "format-icons": {
      "default": ["๓ฐฟ", "๓ฐ", "๓ฐพ"]
    }
  },

  "tray": {
    "icon-size": 18,
    "spacing": 8
  },

  "custom/waycal": {
    "format": "๓ฐญ",
    "on-click": "pkill -x waycal || waycal",
    "interval": "once",
    "tooltip": false
  }
}
