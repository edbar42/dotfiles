@define-color background rgba(21, 25, 31, 0.85);
@define-color background-solid #21252b;
@define-color surface rgba(40, 44, 52, 0.90);
@define-color border rgba(171, 178, 191, 0.09);
@define-color foreground #abb2bf;
@define-color comment #5c6370;

@define-color red #e06c75;
@define-color green #98c379;
@define-color yellow #e5c07b;
@define-color orange #d19a66;
@define-color blue #61afef;
@define-color magenta #c678dd;
@define-color cyan #56b6c2;

* {
  border: none;
  min-height: 0;
  font-family: "CaskaydiaCoveNF", "Font Awesome 6 Free";
  font-size: 15px;
  font-weight: 700;
}

window#waybar {
  background: @background;
  color: @foreground;
  border-bottom: 1px solid rgba(97, 175, 239, 0.12);
}

tooltip {
  background: rgba(21, 25, 31, 0.97);
  border: 1px solid @border;
  border-radius: 10px;
}

tooltip label {
  color: @foreground;
  padding: 2px;
}

#workspaces,
#custom-waycal,
#clock,
#memory,
#custom-cputemp,
#custom-gputemp,
#network,
#pulseaudio,
#battery,
#language,
#custom-expand-icon,
#tray {
  margin: 4px 3px;
  padding: 0 12px;
  min-height: 26px;
  color: @foreground;
  background: @surface;
  border: 1px solid @border;
  border-radius: 10px;
}

#quick-settings {
  background: transparent;
  border: none;
  margin: 0;
  padding: 0;
}

.quick-settings-item {
  background: transparent;
  border: none;
  box-shadow: none;
  margin-top: 4px;
  margin-bottom: 4px;
}

#workspaces {
  margin-left: 8px;
  padding: 2px 6px;
}

#workspaces button {
  min-width: 22px;
  margin: 0 2px;
  padding: 0 8px;
  color: @comment;
  background: transparent;
  border-radius: 8px;
}

#workspaces button:hover {
  color: @foreground;
  background: rgba(171, 178, 191, 0.10);
}

#workspaces button.active {
  color: @foreground;
  background: rgba(171, 178, 191, 0.12);
  box-shadow: inset 0 0 0 1px rgba(171, 178, 191, 0.18);
}

#workspaces button.urgent {
  color: @background-solid;
  background: @red;
}

/* Center island: waycal + clock */
#custom-waycal {
  margin-right: 0;
  padding: 0 10px;
  font-size: 16px;
  color: @yellow;
  border-right: none;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

#clock {
  margin-left: 0;
  padding: 0 14px 0 10px;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: @foreground;
  border-left: none;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

/* System stats island — memory is always left cap */
#memory {
  margin-right: 0;
  border-right: none;
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
  color: @blue;
}

{{ if eq .chezmoi.hostname "desktop" -}}
#custom-cputemp {
  margin-left: 0;
  margin-right: 0;
  border-radius: 0;
  border-left: none;
  border-right: none;
  color: @orange;
}

#custom-gputemp {
  margin-left: 0;
  border-left: none;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  color: @green;
}
{{ else -}}
#custom-cputemp {
  margin-left: 0;
  border-left: none;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  color: @orange;
}
{{ end }}

#network {
  color: @cyan;
}

#pulseaudio {
  color: @foreground;
}

#battery {
  color: @green;
}

#language {
  padding: 0 12px;
  color: @magenta;
  font-weight: 800;
}

#tray {
  padding: 0 10px;
}

#tray > .passive {
  -gtk-icon-effect: dim;
}

#tray > .needs-attention {
  -gtk-icon-effect: highlight;
}

#network.disconnected,
#pulseaudio.muted,
#battery.critical:not(.charging) {
  color: @red;
  background: rgba(224, 108, 117, 0.12);
}

#battery.warning {
  color: @yellow;
  background: rgba(229, 192, 123, 0.10);
}

#battery.charging,
#battery.plugged {
  color: @green;
  background: rgba(152, 195, 121, 0.12);
}

@keyframes blink {
  to {
    color: @foreground;
  }
}

#battery.critical:not(.charging) {
  animation-name: blink;
  animation-duration: 0.7s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

#custom-cputemp.warn,
#custom-gputemp.warn {
  color: @yellow;
}

#custom-cputemp.crit,
#custom-gputemp.crit {
  animation-name: blink;
  animation-duration: 0.7s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}
